# Your Anthropic API key (from console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-...

# The folder your BUILD agents can read, write, and run commands in.
# Point this at the repo you want the agents to work on, e.g. BrightBase.
WORKSPACE_DIR=/Users/megan/code/brightbase

# Model alias the agents run on (sonnet | opus | haiku, or a full model id).
AGENT_MODEL=sonnet
